# ── Hisense TV Sports AI Assistant — hosted agent environment ──────────
# Copy to `.env` and fill in for LIVE mode. Leave unset (or POC_OFFLINE=1)
# to run fully OFFLINE with local mock data (no Azure needed).

# Force offline mode even if a project endpoint is set (handy for demos/tests).
# POC_OFFLINE=1

# ── Foundry project + model (Feature: hosted agent) ───────────────────
# Injected automatically when running as a Foundry hosted agent. Set locally
# only for live local runs.
# FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project>
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# ── Foundry IQ knowledge base (Feature 1) ─────────────────────────────
# The AI Search knowledge-agent / knowledge-base that powers agentic retrieval.
# If unset, foundry_iq_search uses the local KB docs in data/kb/.
# FOUNDRY_IQ_ENDPOINT=https://<your-search>.search.windows.net
# FOUNDRY_IQ_KNOWLEDGE_BASE=hisense-epg-kb

# ── Web IQ (Feature 2) ────────────────────────────────────────────────
# API key for api.microsoft.ai (x-apikey auth). If unset, webiq_search
# returns a labelled offline stub.
# WEBIQ_API_KEY=<your-webiq-api-key>
# WEBIQ_BASE_URL=https://api.microsoft.ai/v3

# ── Tracing / Monitoring (Feature 4) ──────────────────────────────────
# Injected by the platform when deployed. Enables OpenTelemetry → App Insights.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# OTEL_AUTO_CONFIGURE_AZURE_MONITOR=true
# AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true
