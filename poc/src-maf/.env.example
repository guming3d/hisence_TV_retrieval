# ── Hisense TV Sports AI Assistant — MAF harness hosted agent ─────────
# Copy to `.env` and fill in for LIVE mode. Leave unset (or POC_OFFLINE=1)
# to run fully OFFLINE with local mock data (no Azure needed).

# Force offline mode even if a project endpoint is set (handy for demos/tests).
# POC_OFFLINE=1

# ── Foundry project + model (hosted agent) ────────────────────────────
# Injected automatically when running as a Foundry hosted agent. Set locally
# only for live local runs.
# FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project>
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# ── Foundry IQ knowledge base ─────────────────────────────────────────
# The AI Search knowledge-agent / knowledge-base that powers agentic retrieval.
# If unset, foundry_iq_search uses the local KB docs in data/kb/.
# FOUNDRY_IQ_ENDPOINT=https://<your-search>.search.windows.net
# FOUNDRY_IQ_KNOWLEDGE_BASE=hisense-kb
# FOUNDRY_IQ_KNOWLEDGE_SOURCE=hisense-kb-source

# ── Web IQ ────────────────────────────────────────────────────────────
# API key for api.microsoft.ai (x-apikey auth). If unset, webiq_search
# returns a labelled offline stub.
# WEBIQ_API_KEY=<your-webiq-api-key>
# WEBIQ_BASE_URL=https://api.microsoft.ai/v3

# ── Foundry Memory (cross-session viewer-preference memory) ───────────
# Managed memory store name. If unset (or offline), the memory tools fall back
# to a local per-viewer JSON store under data/memory/.
# MEMORY_STORE_NAME=hisense-viewer-memory
# MEMORY_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# MEMORY_DEFAULT_VIEWER=demo-viewer
# MEMORY_MAX_RECALL=5

# ── Foundry Skills (preview) — runtime delivery source ────────────────
# SKILLS_SOURCE=auto
# SKILLS_TOOLBOX_NAME=hisense-tv-skills

# ── Observability (Agent Framework native instrumentation) ────────────
# MAF is natively instrumented; Foundry Hosted Agents manage the OTel exporters
# and inject APPLICATIONINSIGHTS_CONNECTION_STRING on deploy. For local runs,
# set the connection string to send telemetry to Application Insights.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# ENABLE_SENSITIVE_DATA=true            # capture prompts/tool args in traces
# OTEL_AUTO_CONFIGURE_AZURE_MONITOR=true
# AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true
